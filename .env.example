# ==============================================================================
# AI-Proctored Online Examination Platform - Environment Configuration Template
# Copy this file to '.env' and fill in the actual values.
# ==============================================================================

# General
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME="AI-Proctored Online Examination Platform"

# Backend configuration
BACKEND_PORT=8000
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_me
POSTGRES_DB=proctored_exam_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Security & JWT Authentication
# Run `openssl rand -hex 32` to generate a secure secret key
JWT_SECRET_KEY=supersecretkeythatisatleast32characterslongpleasechangeinproduction
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Frontend configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# AI/Proctoring Configuration (Placeholders for Future Implementations)
AI_SERVICE_API_KEY=your_ai_api_key_here
PROCTORING_CONFIDENCE_THRESHOLD=0.75
